NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

NEO4J_USER=neo4j
NEO4J_PASSWORD=# Add your own

NEO4J_PLUGINS=["apoc"]

NEO4J_HEAP_INITIAL_SIZE=512m
NEO4J_HEAP_MAX_SIZE=1G
NEO4J_PAGECACHE_SIZE=512m

NEODASH_PORT=5005

NEODASH_STANDALONE=false
NEODASH_SSO_ENABLED=false

# Gemini
GEMINI_API_KEY=# Add your own
GEMINI_MODEL= gemini-3.5-flash

# Ollama
# OLLAMA_MODEL=gemma2:2b
OLLAMA_MODEL=llama3.2:3b
OLLAMA_URL=http://localhost:11434

# OpenRouter
OPENROUTER_API_KEY=#Add your own
OPENROUTER_MODEL=google/gemini-2.5-flash

APP_ENV=development